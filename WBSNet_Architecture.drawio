    <diagram id="WBS_Module_Detail" name="WBS Module Internals">
        <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="d2_title" value="&lt;b&gt;WBS Module — Internal Data Flow&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;fontColor=#1F4E79;" vertex="1" parent="1">
                    <mxGeometry x="400" y="20" width="400" height="35" as="geometry"/>
                </mxCell>
                <!-- Step 1 -->
                <mxCell id="s1" value="&lt;b&gt;Step 1: Input&lt;/b&gt;&lt;br&gt;Encoder feature F_enc&lt;br&gt;Shape: [B, C, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="80" y="100" width="180" height="70" as="geometry"/>
                </mxCell>
                <!-- Step 2 -->
                <mxCell id="s2" value="&lt;b&gt;Step 2: DWT&lt;/b&gt;&lt;br&gt;Apply 2D Haar Wavelet&lt;br&gt;LL: [B, C, H/2, W/2]&lt;br&gt;LH,HL,HH: each [B, C, H/2, W/2]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996699;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="340" y="80" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s1s2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="s1" target="s2" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Step 3a: LFSA -->
                <mxCell id="s3a" value="&lt;b&gt;Step 3a: LFSA&lt;/b&gt;&lt;br&gt;LL → GAP → FC → ReLU → FC → σ&lt;br&gt;Channel weights w ∈ R^C&lt;br&gt;LL&#39; = LL ⊙ w" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#27ae60;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="640" y="80" width="220" height="90" as="geometry"/>
                </mxCell>
                <!-- Step 3b: HFBA -->
                <mxCell id="s3b" value="&lt;b&gt;Step 3b: HFBA&lt;/b&gt;&lt;br&gt;HF = cat(LH,HL,HH) → [B, 3C, H/2, W/2]&lt;br&gt;→ DWConv3×3 → PWConv1×1 → BN → ReLU&lt;br&gt;→ Conv1×1 = M_bnd logits&lt;br&gt;HF_attended = HF_reduced ⊙ sigmoid(M_bnd)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#e67e22;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="640" y="220" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s2s3a" value="LL" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.3;entryX=0;entryY=0.5;strokeColor=#27ae60;strokeWidth=2;" edge="1" source="s2" target="s3a" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s2s3b" value="LH,HL,HH" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.7;entryX=0;entryY=0.5;strokeColor=#e67e22;strokeWidth=2;" edge="1" source="s2" target="s3b" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Boundary GT Supervision -->
                <mxCell id="bgt2" value="&lt;b&gt;Boundary GT&lt;/b&gt;&lt;br&gt;(training only)&lt;br&gt;BCEWithLogits(M_bnd, resized edge GT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="640" y="380" width="250" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="s3b_bgt" value="supervise" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;dashed=1;" edge="1" source="s3b" target="bgt2" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Step 4: IDWT -->
                <mxCell id="s4" value="&lt;b&gt;Step 4: IDWT&lt;/b&gt;&lt;br&gt;Reuse HF_attended for LH&#39;, HL&#39;, HH&#39;&lt;br&gt;F_skip&#39; = IDWT(LL&#39;, HF_attended, HF_attended, HF_attended)&lt;br&gt;Shape: [B, C, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996699;fontSize=10;" vertex="1" parent="1">
                    <mxGeometry x="980" y="160" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s3as4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#27ae60;strokeWidth=2;" edge="1" source="s3a" target="s4" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s3bs4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#e67e22;strokeWidth=2;" edge="1" source="s3b" target="s4" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Step 5: Concat + Output -->
                <mxCell id="s5" value="&lt;b&gt;Step 5: Output&lt;/b&gt;&lt;br&gt;F_skip&#39; concatenated with&lt;br&gt;upsampled decoder feature&lt;br&gt;→ Decoder Conv Block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#196f3d;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="1280" y="160" width="220" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s4s5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#196f3d;strokeWidth=2;" edge="1" source="s4" target="s5" parent="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <!-- Equations box -->
                <mxCell id="eqs" value="&lt;b&gt;Key Equations:&lt;/b&gt;&lt;br&gt;(LL, LH, HL, HH) = DWT(F_enc)&lt;br&gt;LL&#39; = LL ⊙ σ(FC₂(ReLU(FC₁(GAP(LL)))))&lt;br&gt;HF = Concat(LH, HL, HH)&lt;br&gt;M_bnd = Conv1×1(ReLU(BN(PWConv(DWConv(HF)))))&lt;br&gt;HF_attended = HF_reduced ⊙ sigmoid(M_bnd)&lt;br&gt;F_skip&#39; = IDWT(LL&#39;, HF_attended, HF_attended, HF_attended)&lt;br&gt;L_total = BCEWithLogits + Dice + λ · mean_k BCEWithLogits(M_bnd^(k), edge_k)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="80" y="500" width="420" height="170" as="geometry"/>
                </mxCell>
                <!-- Parameter count box -->
                <mxCell id="params" value="&lt;b&gt;Parameter Overhead per WBS Module:&lt;/b&gt;&lt;br&gt;LFSA: 2 × FC layers ≈ 2C²/r&lt;br&gt;HFBA: DWConv3×3 + PWConv1×1 + logits head&lt;br&gt;Depthwise-separable HFBA keeps the skip module lightweight&lt;br&gt;&lt;br&gt;&lt;b&gt;Estimated total overhead (4 modules):&lt;/b&gt;&lt;br&gt;C = [64, 64, 128, 256] → ~1.1M additional params&lt;br&gt;(with r=16 reduction ratio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
                    <mxGeometry x="560" y="500" width="380" height="170" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
