                <mxCell id="hfba_box" value="[LH,HL,HH] → DWConv3×3 → PWConv1×1 → BN → ReLU&lt;br&gt;M_bnd logits = Conv1×1(HF_reduced), A_bnd = sigmoid(M_bnd)&lt;br&gt;HF_attended = HF_reduced ⊙ A_bnd, supervised with BCEWithLogits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#e67e22;fontSize=9;" parent="1" vertex="1">
