%%{init: {'theme':'neutral','flowchart':{'curve':'basis','nodeSpacing':40,'rankSpacing':60}}}%%
flowchart LR
    X["Input RGB<br/>3 x H x W"] --> STEM["Stem + ReLU<br/>64 x H/2 x W/2"]
    STEM --> MP["MaxPool"]
    MP --> L1["Layer1<br/>64 x H/4 x W/4"]
    L1 --> L2["Layer2<br/>128 x H/8 x W/8"]
    L2 --> L3["Layer3<br/>256 x H/16 x W/16"]
    L3 --> L4["Layer4 (bottleneck)<br/>512 x H/32 x W/32"]

    STEM --> WBS1["WBS Module 1<br/>C = 64"]
    L1   --> WBS2["WBS Module 2<br/>C = 64"]
    L2   --> WBS3["WBS Module 3<br/>C = 128"]
    L3   --> WBS4["WBS Module 4<br/>C = 256"]

    WBS1 -.->|"boundary logits k=1"| LBND
    WBS2 -.->|"boundary logits k=2"| LBND
    WBS3 -.->|"boundary logits k=3"| LBND
    WBS4 -.->|"boundary logits k=4"| LBND["L_bnd<br/>(Sobel GT at each scale)"]

    L4 --> D4["Decoder stage 4<br/>Up + Concat(WBS4) + 2x Conv<br/>256 x H/16 x W/16"]
    WBS4 --> D4
    D4 --> D3["Decoder stage 3<br/>128 x H/8 x W/8"]
    WBS3 --> D3
    D3 --> D2["Decoder stage 2<br/>64 x H/4 x W/4"]
    WBS2 --> D2
    D2 --> D1["Decoder stage 1<br/>32 x H/2 x W/2"]
    WBS1 --> D1
    D1 --> UP["Upsample x2"]
    UP --> HEAD["1x1 Conv head"]
    HEAD --> OUT["logits<br/>1 x H x W"]
    OUT --> LSEG["L_seg = BCE + Dice"]

    LSEG --> LTOT["L = L_seg + 0.5 L_bnd"]
    LBND --> LTOT
